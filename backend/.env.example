# ============================================
# Azure OpenAI Realtime API Configuration
# ============================================
# Required for voice-only interview feature
# Get these from Azure Portal: Azure OpenAI resource
# 1. Create Azure OpenAI resource in Azure Portal
# 2. Deploy gpt-4o-realtime model
# 3. Get API key and endpoint from resource overview
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-realtime
# Separate deployment for chat completions used by feedback/report chains
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-01-preview
# Optional: realtime voice profile (for interview TTS). Example local value: ash
REALTIME_VOICE=alloy

# ============================================
# Fallback: OpenAI Realtime API
# ============================================
# Use if Azure OpenAI is not available
# Get from https://platform.openai.com/api-keys
OPENAI_REALTIME_API_KEY=your-openai-api-key-here
OPENAI_REALTIME_ENDPOINT=https://api.openai.com/v1/realtime
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# ============================================
# Azure Speech Services
# ============================================
# Optional: For enhanced speech-to-text transcription
# Get from Azure Portal: Cognitive Services - Speech Services
# Resource: projectespeech (centralindia region)
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=centralindia
AZURE_SPEECH_ENDPOINT=https://centralindia.api.cognitive.microsoft.com/

# ============================================
# Azure Cognitive Services (Legacy)
# ============================================
# For other Azure Cognitive Services features
AZURE_COGNITIVE_KEY=your-azure-cognitive-key-here
AZURE_API_KEY=your-azure-api-key-here

# ============================================
# Database (Auth & user persistence)
# ============================================
# Default: backend/app.db (set for custom path)
# DATABASE_URL=sqlite:///./app.db
# Azure PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ============================================
# Authentication (Clerk)
# ============================================
# Backend derives JWKS from CLERK_PUBLISHABLE_KEY if CLERK_JWKS_URL is not set
CLERK_SECRET_KEY=your-clerk-secret-key-here
CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key-here
# Optional: override JWKS URL (e.g. https://<instance>.clerk.accounts.dev/.well-known/jwks.json)
# CLERK_JWKS_URL=

# ============================================
# CORS / Allowed Origins
# ============================================
# Comma-separated list of origins allowed to access the API in production (e.g. your frontend domain)
# Example:
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# For local development you can leave this unset and the app will enable localhost origins by default.
# Setting ALLOWED_ORIGINS='*' will allow all origins (not recommended for production).
# ALLOWED_ORIGINS=

# ============================================
# Redis (Session & event storage)
# ============================================
# Local example:
# REDIS_URL=redis://localhost:6379
# Azure Cache for Redis example (TLS):
# REDIS_URL=rediss://:PASSWORD@HOST:6380


# ============================================
# Azure AD Authentication
# ============================================
# For Azure AD-based authentication (alternative to API keys)
AZURE_REALTIME_SCOPE=https://ai.azure.com/.default

# ============================================
# OpenAI API (Legacy)
# ============================================
# For other OpenAI features
OPENAI_API_KEY=your-openai-api-key-here
