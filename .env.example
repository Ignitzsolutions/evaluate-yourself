# Frontend (Create React App) — copy to .env and fill in
# Restart "npm start" after changing .env

# Backend API URL
REACT_APP_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# Optional realtime voice preference for browser session.update
REACT_APP_REALTIME_VOICE=alloy

# Optional: enable browser speech recognition fallback when provider transcript events are unavailable
REACT_APP_ENABLE_BROWSER_SR_FALLBACK=true
# Optional: force dual transcription keys in session.update for legacy model compatibility
REACT_APP_REALTIME_SESSION_DUAL_TRANSCRIPTION_KEYS=true
# Optional: transcription model used in session.update
REACT_APP_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
